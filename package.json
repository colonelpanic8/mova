{
  "name": "mova",
  "main": "./index.js",
  "version": "6.5.0",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:components": "jest --selectProjects components",
    "test:coverage": "jest --coverage",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:build:android:x86_64": "cd android && ./gradlew :app:assembleDebug :app:assembleDebugAndroidTest -DtestBuildType=debug -PreactNativeArchitectures=x86_64",
    "e2e:test:android": "detox test --configuration android.emu.debug",
    "e2e:android": "detox test --configuration android.emu.debug --build",
    "e2e:local-api:start": "./e2e/local-api.sh start",
    "e2e:local-api:stop": "./e2e/local-api.sh stop",
    "e2e:local-api:status": "./e2e/local-api.sh status",
    "lint": "expo lint",
    "lint:fix": "eslint . --fix",
    "typecheck": "expo customize tsconfig.json >/dev/null && tsc && tsc -p e2e/tsconfig.json",
    "format:check": "prettier . --check",
    "format": "prettier . --write",
    "validate": "yarn typecheck && yarn lint && yarn format:check",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@tanstack/query-async-storage-persister": "^5.101.4",
    "@tanstack/react-query": "^5.101.4",
    "@tanstack/react-query-persist-client": "^5.101.4",
    "expo": "^57.0.0",
    "expo-background-fetch": "~57.0.6",
    "expo-constants": "~57.0.7",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-task-manager": "~57.0.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-android-widget": "^0.21.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-paper": "^5.15.3",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@react-native/jest-preset": "0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/react": "~19.2.10",
    "detox": "^20.46.3",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~57.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~6.0.3"
  },
  "private": true,
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      }
    }
  },
  "buildNumber": "9"
}
