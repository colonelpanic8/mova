<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_preview_background"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <!-- Mic circle -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="9dp"
            android:background="@drawable/circle_primary"
            android:src="@drawable/ic_mic"
            android:tint="@color/md_on_primary"
            android:scaleType="fitCenter"
            android:contentDescription="Capture by voice" />

        <!-- Text area -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingLeft="14dp"
            android:paddingRight="10dp"
            android:text="Add a todo…"
            android:textColor="@color/md_on_surface_variant"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Send circle -->
        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="10dp"
            android:background="@drawable/circle_primary_container"
            android:src="@drawable/ic_send"
            android:tint="@color/md_on_primary_container"
            android:scaleType="fitCenter"
            android:contentDescription="Add a todo" />

    </LinearLayout>

</FrameLayout>
